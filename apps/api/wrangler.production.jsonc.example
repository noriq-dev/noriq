// Your instance's deployment config — copy to wrangler.production.jsonc (gitignored)
// and fill in your values. `npm run deploy` picks it up automatically when present;
// without it, the generic wrangler.jsonc deploys to <name>.workers.dev.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "noriq",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],

  // Your custom domain (zone must be on your Cloudflare account). Wrangler
  // creates the DNS record + certificate on deploy. Delete to use workers.dev.
  "routes": [{ "pattern": "noriq.example.com", "custom_domain": true }],

  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/mcp", "/mcp/*", "/ws", "/ws/*", "/oauth/*", "/.well-known/*", "/skill.md", "/skill/*", "/reference.md", "/reference.json"]
  },

  "durable_objects": {
    "bindings": [
      { "name": "PROJECT_ROOM", "class_name": "ProjectRoom" },
      { "name": "AGENT_SESSION", "class_name": "AgentSession" },
      { "name": "RATE_LIMITER", "class_name": "RateLimiter" },
      { "name": "RUNNER_HUB", "class_name": "RunnerHub" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ProjectRoom", "AgentSession"] },
    { "tag": "v2", "new_sqlite_classes": ["RateLimiter"] },
    { "tag": "v3", "new_sqlite_classes": ["RunnerHub"] }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "noriq",
      "database_id": "<your d1 database id from: wrangler d1 create noriq>",
      "migrations_dir": "migrations"
    }
  ],

  // OPTIONAL — email invites. Requires: wrangler email sending enable <your-domain>
  // Delete both if unused; invites fall back to copyable links.
  "send_email": [{ "name": "EMAIL" }],
  "vars": { "EMAIL_FROM": "noriq@example.com" },

  // OPTIONAL — task attachments. Requires R2 enabled on the account, then:
  //   wrangler r2 bucket create noriq-files
  // Delete if unused; the attachments UI reports it as not configured.
  "r2_buckets": [{ "binding": "FILES", "bucket_name": "noriq-files" }],


  // OPTIONAL — semantic search (PLNR-184). AI = Workers AI embeddings (no provisioning
  // needed). VECTORIZE is opt-in: create the index first, then keep the binding below —
  //   wrangler vectorize create noriq-search --dimensions=1024 --metric=cosine
  //   wrangler vectorize create-metadata-index noriq-search --property-name=projectId --type=string
  // Delete the vectorize line if unused; search transparently degrades to keyword matching.
  "ai": { "binding": "AI" },
  "vectorize": [{ "binding": "VECTORIZE", "index_name": "noriq-search" }],

  // Daily D1 backup to R2 at 06:00 UTC (PLNR-21); snapshots land under backups/ (see BACKUP.md).
  "triggers": { "crons": ["0 6 * * *"] },

  "observability": { "enabled": true }
}
